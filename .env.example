# ╔══════════════════════════════════════════════════════════╗
# ║  ULTRA SYSTEM - Variables de Entorno                     ║
# ║  Copia este archivo: cp .env.example .env                ║
# ║  Luego edita .env con tus credenciales reales            ║
# ╚══════════════════════════════════════════════════════════╝

# ─── PostgreSQL (única dependencia) ───────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ─── Telegram Bot ─────────────────────────────────────────
# 1. Habla con @BotFather en Telegram → /newbot
# 2. Copia el token que te da
TELEGRAM_BOT_TOKEN=
# 3. Envía un mensaje a tu bot, luego ejecuta:
#    curl https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#    Busca "chat":{"id": TU_NUMERO}
TELEGRAM_CHAT_ID=

# ─── API Authentication ──────────────────────────────────
# Genera una key segura: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: Cambiar esta key en produccion. La de abajo es solo un placeholder.
API_KEY=865aedd1cb48cce21dfbddd4d89223904534b80706ec8188c87e34043f00aed8_CHANGE_IN_PRODUCTION

# ─── General ─────────────────────────────────────────────
TZ=Pacific/Auckland

# ─── Deploy / SSH al servidor ────────────────────────────
DEPLOY_HOST=
DEPLOY_PORT=22
DEPLOY_USER=root
DEPLOY_SSH_KEY=
DEPLOY_PASS=

# ════════════════════════════════════════════════════════════
#  TIER A KEYED STUBS — paste credentials to activate
#  Each entry below has a working fetcher already coded.
#  When the env var is empty, fetcher returns { skipped }.
#  When set, the cron picks it up automatically.
# ════════════════════════════════════════════════════════════

# ─── P1 NEWS APIs ───────────────────────────────────────────
# Currents API — 1k req/día, 70+ países
# https://currentsapi.services/en/register
CURRENTS_API_KEY=
# Newsdata.io — 200 credits/día, 206 países, 89 idiomas
# https://newsdata.io/register
NEWSDATA_API_KEY=
# NewsAPI.ai (Event Registry) — 2k searches/mes
# https://eventregistry.org/register
EVENT_REGISTRY_API_KEY=
# Finlight.me — 10k req/mes financial
# https://finlight.me/signup
FINLIGHT_API_KEY=
# YouTube Data API v3 — 10k units/día
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=
# Mastodon search (rate limit superior)
# https://mastodon.social/settings/applications
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=
# Podcast Index — gratis ilimitado
# https://api.podcastindex.org/signup
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=
# ACLED conflict events
# https://developer.acleddata.com/
ACLED_API_KEY=
ACLED_EMAIL=

# ─── P2 EMPLEO ──────────────────────────────────────────────
# USAJobs
# https://developer.usajobs.gov/APIRequest/Index
USAJOBS_EMAIL=
USAJOBS_API_KEY=
# France Travail (ex Pôle Emploi)
# https://francetravail.io/data/api
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
# Bundesagentur für Arbeit
# https://jobsuche.api.bund.dev/
BUNDESAGENTUR_CLIENT_ID=
# Adzuna (jobs)
# https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ─── P3 FINANZAS ────────────────────────────────────────────
# Wise multi-currency
# https://wise.com/user/account-settings/security
WISE_API_TOKEN=
WISE_PROFILE_ID=
# Akahu (NZ open banking)
# https://my.akahu.nz/developers/
AKAHU_APP_TOKEN=
AKAHU_USER_TOKEN=
# Binance read-only
# https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=
# CoinGecko Pro (opcional, free funciona sin key)
COINGECKO_API_KEY=

# ─── P4 BUROCRACIA ──────────────────────────────────────────
# Apprise (multi-channel notifier — activar container con --profile notify)
APPRISE_URL=
APPRISE_KEY=ultra
# n8n workflow automation (--profile automation)
N8N_USER=admin
N8N_PASSWORD=changeme
N8N_WEBHOOK_URL=
# OpenAI (opcional, paperless-ai)
OPENAI_API_KEY=
# Webhook secret (cuando se exponen webhooks públicamente)
WEBHOOK_SECRET=

# ─── P5 OPORTUNIDADES (quest platforms) ─────────────────────
# Galxe
# https://galxe.com (settings → API)
GALXE_API_KEY=
# Layer3
# https://layer3.xyz
LAYER3_API_KEY=
# Zealy
# https://zealy.io
ZEALY_API_KEY=
ZEALY_SUBDOMAIN=

# ─── P6 LOGÍSTICA ───────────────────────────────────────────
# Open Charge Map (EV chargers) — gratis
# https://openchargemap.org/site/develop/api
OCM_API_KEY=
# WiFi Map
# https://www.wifimap.io/api
WIFIMAP_API_KEY=
# BlaBlaCar Public API
# https://www.blablacar.com/api
BLABLACAR_API_KEY=
# Booking.com Demand API
# https://developers.booking.com
BOOKING_API_KEY=

# ─── P7 BIO-CHECK (wearables) ───────────────────────────────
# Fitbit OAuth — callback: https://YOUR-DOMAIN/webhooks/wearable/fitbit/callback
# https://dev.fitbit.com/apps/new
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
# Withings OAuth — callback: https://YOUR-DOMAIN/webhooks/wearable/withings/callback
# https://developer.withings.com/dashboard/
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
# Oura Ring — Personal Token (no OAuth)
# https://cloud.ouraring.com/personal-access-tokens
OURA_PERSONAL_TOKEN=
# Garmin Connect IQ
# https://developer.garmin.com/gc-developer-program/connect-iq/
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
# USDA FoodData Central — gratis
# https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=
# OpenUV (UV index)
# https://www.openuv.io/auth/google
OPENUV_API_KEY=
# CalorieNinjas
# https://calorieninjas.com/register
CALORIE_NINJAS_KEY=
