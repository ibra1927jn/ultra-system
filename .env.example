# ╔══════════════════════════════════════════════════════════╗
# ║  ULTRA SYSTEM - Variables de Entorno                     ║
# ║  Copia este archivo: cp .env.example .env                ║
# ║  Luego edita .env con tus credenciales reales            ║
# ╚══════════════════════════════════════════════════════════╝

# ─── PostgreSQL (única dependencia) ───────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ─── Telegram Bot ─────────────────────────────────────────
# 1. Habla con @BotFather en Telegram → /newbot
# 2. Copia el token que te da
TELEGRAM_BOT_TOKEN=
# 3. Envía un mensaje a tu bot, luego ejecuta:
#    curl https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#    Busca "chat":{"id": TU_NUMERO}
TELEGRAM_CHAT_ID=

# ─── API Authentication ──────────────────────────────────
# Genera una key segura: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: Cambiar esta key en produccion. La de abajo es solo un placeholder.
API_KEY=865aedd1cb48cce21dfbddd4d89223904534b80706ec8188c87e34043f00aed8_CHANGE_IN_PRODUCTION

# ─── General ─────────────────────────────────────────────
TZ=Pacific/Auckland

# ─── Deploy / SSH al servidor ────────────────────────────
DEPLOY_HOST=
DEPLOY_PORT=22
DEPLOY_USER=root
DEPLOY_SSH_KEY=
DEPLOY_PASS=

# ════════════════════════════════════════════════════════════
#  TIER A KEYED STUBS — paste credentials to activate
#  Each entry below has a working fetcher already coded.
#  When the env var is empty, fetcher returns { skipped }.
#  When set, the cron picks it up automatically.
# ════════════════════════════════════════════════════════════

# ─── P1 NEWS APIs ───────────────────────────────────────────
# Currents API — 1k req/día, 70+ países
# https://currentsapi.services/en/register
CURRENTS_API_KEY=
# Newsdata.io — 200 credits/día, 206 países, 89 idiomas
# https://newsdata.io/register
NEWSDATA_API_KEY=
# NewsAPI.ai (Event Registry) — 2k searches/mes
# https://eventregistry.org/register
EVENT_REGISTRY_API_KEY=
# Finlight.me — 10k req/mes financial
# https://finlight.me/signup
FINLIGHT_API_KEY=
# YouTube Data API v3 — 10k units/día
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=
# Mastodon search (rate limit superior)
# https://mastodon.social/settings/applications
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=
# Podcast Index — gratis ilimitado
# https://api.podcastindex.org/signup
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=
# ACLED conflict events
# https://developer.acleddata.com/
ACLED_EMAIL=
ACLED_PASSWORD=

# ─── P2 EMPLEO ──────────────────────────────────────────────
# USAJobs
# https://developer.usajobs.gov/APIRequest/Index
USAJOBS_EMAIL=
USAJOBS_API_KEY=
# France Travail (ex Pôle Emploi)
# https://francetravail.io/data/api
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
# Bundesagentur für Arbeit
# https://jobsuche.api.bund.dev/
BUNDESAGENTUR_CLIENT_ID=
# Adzuna (jobs)
# https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ─── P3 FINANZAS ────────────────────────────────────────────
# Wise multi-currency
# https://wise.com/user/account-settings/security
WISE_API_TOKEN=
WISE_PROFILE_ID=
# Akahu (NZ open banking)
# https://my.akahu.nz/developers/
AKAHU_APP_TOKEN=
AKAHU_USER_TOKEN=
# Binance read-only
# https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=
# CoinGecko Pro (opcional, free funciona sin key)
COINGECKO_API_KEY=

# ─── P4 BUROCRACIA ──────────────────────────────────────────
# Apprise (multi-channel notifier — activar container con --profile notify)
APPRISE_URL=
APPRISE_KEY=ultra
# n8n workflow automation (--profile automation)
N8N_USER=admin
N8N_PASSWORD=changeme
N8N_WEBHOOK_URL=
# OpenAI (opcional, paperless-ai)
OPENAI_API_KEY=
# Webhook secret (cuando se exponen webhooks públicamente)
WEBHOOK_SECRET=

# ─── P5 OPORTUNIDADES (quest platforms) ─────────────────────
# Galxe
# https://galxe.com (settings → API)
GALXE_API_KEY=
# Layer3
# https://layer3.xyz
LAYER3_API_KEY=
# Zealy
# https://zealy.io
ZEALY_API_KEY=
ZEALY_SUBDOMAIN=

# ─── P6 LOGÍSTICA ───────────────────────────────────────────
# Open Charge Map (EV chargers) — gratis
# https://openchargemap.org/site/develop/api
OCM_API_KEY=
# WiFi Map
# https://www.wifimap.io/api
WIFIMAP_API_KEY=
# BlaBlaCar Public API
# https://www.blablacar.com/api
BLABLACAR_API_KEY=
# Booking.com Demand API
# https://developers.booking.com
BOOKING_API_KEY=

# ─── P7 BIO-CHECK (wearables) ───────────────────────────────
# ─── BIO CONTAINERS (P7 — wger workouts → bio_journal) ────
# Wger fitness tracker — token via POST http://wger:8000/api/v2/login {"username":"admin","password":"adminadmin"}
# Cron 'wger-workouts-sync' cada 6h :20 lee /api/v2/workoutsession y los pasa a bio_journal
WGER_API_TOKEN=

# ─── TRACCAR GPS (P6 — log_gps_positions) ─────────────────
# Crea cuenta en UI puerto 8082. Si DB resetada, POST sin auth a /api/users
# crea el primer admin. Después actualiza estos valores.
TRACCAR_USER=admin@ultra.local
TRACCAR_PASS=
TRACCAR_BASE_URL=http://traccar:8082

# ─── WEARABLES (P7 — bio_extras-poll cada 6h) ─────────────
# Cuando completes signups, las funciones bio_extras.fetchOuraDaily/
# fetchFitbitDaily/fetchWithingsDaily empiezan a poblar bio_wearable_raw
# automáticamente. El cron wearable-aggregate (diario 23:50) las propaga
# a bio_checks sin que tengas que tocar más código.

# Oura Ring — Personal Token (más simple, NO OAuth, solo header Bearer)
# 1. https://cloud.ouraring.com/personal-access-tokens
# 2. Crear token, copiar valor → pegar abajo
# 3. docker compose up -d engine (recarga env vars, restart NO basta)
# 4. Test: docker compose exec engine node -e "require('./src/bio_extras').fetchOuraDaily().then(console.log)"
OURA_PERSONAL_TOKEN=

# Fitbit OAuth — requiere flow de auth completo
# 1. https://dev.fitbit.com/apps/new — registrar app, callback URL: http://95.217.158.7/webhooks/wearable/fitbit/callback
# 2. Pegar Client ID + Secret abajo
# 3. docker compose up -d engine
# 4. Visitar http://95.217.158.7/api/wearable/fitbit/auth para iniciar OAuth
# 5. Después de autorizar, el access_token se guarda en wearable_credentials
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Withings OAuth — flow similar a Fitbit
# 1. https://developer.withings.com/dashboard/ — registrar app
# 2. Callback URL: http://95.217.158.7/webhooks/wearable/withings/callback
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
# Garmin Connect IQ
# https://developer.garmin.com/gc-developer-program/connect-iq/
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
# USDA FoodData Central — gratis
# https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=
# OpenUV (UV index)
# https://www.openuv.io/auth/google
OPENUV_API_KEY=
# CalorieNinjas
# https://calorieninjas.com/register
CALORIE_NINJAS_KEY=

# ─── Firefly III (P3 ledger migration) ───
# Firefly III es el ledger primario nuevo (R5+). Profile gated:
#   docker compose --profile firefly up -d firefly_iii
# APP_KEY: 32 bytes base64. Generar con: openssl rand -base64 32
FIREFLY_APP_KEY=
# STATIC_TOKEN: 64 hex chars. Generar con: openssl rand -hex 32
FIREFLY_STATIC_TOKEN=
FIREFLY_APP_URL=http://localhost:8080
# PERSONAL_TOKEN: generado dentro de Firefly III en Profile → OAuth → Personal Access Tokens
# Necesario para que el migration script y el bridge en routes/finances.js puedan llamar la API
FIREFLY_PERSONAL_TOKEN=
# Credenciales del primer usuario (= admin). Password min 16 chars.
# Registrado vía POST /register (CSRF flow) al primer boot de ultra_firefly.
FIREFLY_ADMIN_EMAIL=
FIREFLY_ADMIN_PASSWORD=
