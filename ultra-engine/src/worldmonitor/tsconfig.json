{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/config": ["./config/index"],
      "@/config/*": ["./config/*"],
      "@/types": ["./types/index"],
      "@/types/*": ["./types/*"],
      "@/utils": ["./utils/index"],
      "@/utils/*": ["./utils/*"],
      "@/services": ["./services/index"],
      "@/services/*": ["./services/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "PHASE0_IMPORTS_AUDIT.md"
  ]
}
